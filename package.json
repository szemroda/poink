{
  "name": "poink",
  "version": "0.1.0",
  "description": "Local document knowledge base with semantic search, enrichment, and MCP support.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "poink": "dist/cli.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@effect/platform": "^0.96.1",
    "@effect/schema": "^0.75.0",
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@xmldom/xmldom": "^0.9.10",
    "ai": "^6.0.180",
    "dedent": "^1.7.2",
    "dotenv": "^17.4.2",
    "effect": "^3.12.0",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.2",
    "ink-spinner": "^5.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mdast-util-to-string": "^4.0.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "secretlint": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*": "secretlint"
  }
